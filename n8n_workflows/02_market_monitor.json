    {
      "parameters": {
        "functionCode": "// Only run F&O check every 15 minutes (on :00, :15, :30, :45)\nconst minute = new Date().getMinutes();\nif (minute % 15 !== 0) {\n  return [];  // Skip — not a 15-min mark\n}\nreturn [{ json: { run_fo: true } }];"
      },
