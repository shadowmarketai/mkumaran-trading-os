    {
      "parameters": {
        "method": "POST",
        "url": "https://money.shadowmarket.ai/tools/check_exit_strategies",
        "options": { "timeout": 30000, "allowUnauthorizedCerts": true }
      },
      "id": "c1000000-0002-4000-8000-000000000015",
      "name": "Check Exit Strategies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 300]
    },
    {
      "parameters": {
        "functionCode": "const data = $input.first().json;\nconst alerts = [];\n\nconst results = data.results || [];\nfor (const r of results) {\n  const action = r.action || 'HOLD';\n  const ticker = r.ticker || 'UNKNOWN';\n  const pnl = (r.profit_pct || 0).toFixed(1);\n  \n  if (action === 'PARTIAL_50') {\n    alerts.push({ json: { text: `\ud83d\udfe1 ${ticker}: +${pnl}% \u2014 BOOK 50% PROFIT now!`, ticker, action } });\n  } else if (action === 'PARTIAL_25') {\n    alerts.push({ json: { text: `\ud83d\udfe2 ${ticker}: +${pnl}% \u2014 Book another 25%.`, ticker, action } });\n  } else if (action === 'TRAIL_TIGHT') {\n    alerts.push({ json: { text: `\ud83d\ude80 ${ticker}: +${pnl}% \u2014 Tighten trail to 1%!`, ticker, action } });\n  }\n}\n\n// Also check trailing SL updates\nconst slData = $input.all()[0] ? $input.all()[0].json : {};\nconst slResults = slData.results || [];\nfor (const s of slResults) {\n  if (s.updated) {\n    alerts.push({ json: { text: `\ud83d\udd12 ${s.ticker}: SL moved to \u20b9${s.new_sl} (trailing)`, ticker: s.ticker, action: 'TRAIL_UPDATE' } });\n  }\n}\n\nreturn alerts;"
      },
      "id": "c1000000-0002-4000-8000-000000000007",
