    {
      "parameters": {
        "functionCode": "const acc = $input.all()[0].json;\nconst ord = $input.all()[1] ? $input.all()[1].json : {};\nconst reflect = $input.all()[2] ? $input.all()[2].json : {};\nconst memStats = $input.all()[3] ? $input.all()[3].json : {};\nconst portfolio = $input.all()[4] ? $input.all()[4].json : {};\nconst mem = memStats.memory || {};\nconst ref = memStats.reflection || {};\n\nreturn [{ json: {\n  report_type: 'eod',\n  data: {\n    date: new Date().toLocaleDateString('en-IN'),\n    accuracy: { win_rate: acc.win_rate, total_signals: acc.total_signals, open: acc.open, wins: acc.wins, losses: acc.losses, total_pnl_rs: acc.total_pnl_rs, expectancy: acc.expectancy },\n    orders: { open_positions: ord.open_positions, max_positions: ord.max_positions, daily_pnl: ord.daily_pnl, kill_switch_active: ord.kill_switch_active },\n    portfolio: { deployed_pct: portfolio.deployed_pct, sector_breakdown: portfolio.sector_breakdown },\n    memory: { total: mem.total, reflected: mem.reflected, high_conf_win_rate: ref.high_conf_win_rate, today_reflected: reflect.reflected }\n  }\n} }];"
      },
