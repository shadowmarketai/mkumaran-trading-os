    {
      "parameters": {
        "functionCode": "const momentum = $input.first().json;\nconst rankings = momentum.rankings || [];\nconst holdings = momentum.holdings || [];\nconst signals = momentum.signals || [];\n\nif (rankings.length === 0) {\n  return [];\n}\n\nconst top3 = rankings.slice(0, 3).map(r => r.ticker + ' #' + r.rank).join(', ');\nconst buyCount = signals.filter(s => s.action === 'BUY').length;\nconst sellCount = signals.filter(s => s.action === 'SELL').length;\nconst rankedAt = momentum.ranked_at ? momentum.ranked_at.split('T')[0] : 'Never';\n\nconst msg = `\\ud83d\\ude80 Momentum Status\\n\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\nHoldings: ${holdings.length} | Last Scan: ${rankedAt}\\nTop 3: ${top3}\\nSignals: ${buyCount} BUY / ${sellCount} SELL`;\n\nreturn [{ json: { text: msg } }];"
      },
