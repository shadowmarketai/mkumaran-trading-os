# MKUMARAN Trading OS — Environment Variables
# Copy this to .env and fill in your values

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://trading:trading_pass@postgres:5432/trading_os
POSTGRES_PASSWORD=trading_pass

# ── Zerodha Kite (for live trading) ─────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_KEY=

# ── Claude AI (for signal validation) ───────────────────
ANTHROPIC_API_KEY=

# ── Telegram (for alerts & commands) ────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Sheets (for accuracy tracking) ───────────────
GOOGLE_SHEET_ID=
GOOGLE_SHEETS_CREDENTIALS=/app/data/service_account.json

# ── n8n ─────────────────────────────────────────────────
N8N_WEBHOOK_BASE=https://n8n.shadowmarket.ai

# ── MCP Server ──────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001

# ── RRMS Defaults ───────────────────────────────────────
RRMS_CAPITAL=100000
RRMS_RISK_PCT=0.02
RRMS_MIN_RRR=3.0

# ── Razorpay (Subscription Billing) ────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Multi-Agent System ──────────────────────────────────
AGENT_DEFAULT_CAPITAL=1000000
AGENT_TRADE_FEE_RATE=0.001
AGENT_POINTS_EXCHANGE_RATE=1000
