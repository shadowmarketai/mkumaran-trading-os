# MKUMARAN Trading OS — Environment Variables
# Copy this to .env and fill in your values

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://trading:trading_pass@postgres:5432/trading_os
POSTGRES_PASSWORD=trading_pass

# ── Zerodha Kite (for live trading) ─────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_KEY=

# ── Claude AI (for signal validation) ───────────────────
ANTHROPIC_API_KEY=

# ── Telegram (for alerts & commands) ────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Sheets (for accuracy tracking) ───────────────
GOOGLE_SHEET_ID=
GOOGLE_SHEETS_CREDENTIALS=/app/data/service_account.json

# ── n8n ─────────────────────────────────────────────────
N8N_WEBHOOK_BASE=https://n8n.shadowmarket.ai

# ── MCP Server ──────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001

# ── RRMS Defaults ───────────────────────────────────────
RRMS_CAPITAL=100000
RRMS_RISK_PCT=0.02
RRMS_MIN_RRR=3.0

# ── TradingView Scanner (optional, augments Chartink) ──
# Set ENABLED=true to union TradingView screener results into the MWA
# scan pass. Anonymous access returns delayed (~15min) data and is fine
# for EOD scans. For real-time data, paste your sessionid cookie
# (Chrome/Firefox → DevTools → Application → Cookies → tradingview.com
# → sessionid). sessionid_sign is only needed on newer TV deployments.
TRADINGVIEW_SCANNER_ENABLED=false
TRADINGVIEW_SCANNER_LIMIT=500
TRADINGVIEW_SCANNER_CACHE_TTL=300
TRADINGVIEW_SESSIONID=
TRADINGVIEW_SESSIONID_SIGN=

# ── Intraday signals (ORB / VWAP / 5m momentum) ───────────
# Opt-in pipeline running every 5 min during NSE hours on a
# curated F&O watchlist. Separate from daily MWA swing.
INTRADAY_SIGNALS_ENABLED=false
INTRADAY_WATCHLIST=                    # empty = scanner's built-in 30-ticker default
INTRADAY_SCAN_INTERVAL_SEC=300
INTRADAY_MAX_SIGNALS_PER_DAY=5
INTRADAY_RRR_FLOOR=2.0

# ── NeuroLinked brain (cross-product learning) ────────────
# Trading OS fires observations (signals, outcomes, scan summaries,
# postmortems) to a shared brain at brain.shadowmarket.ai. All calls are
# fire-and-forget with a 5s timeout — they never crash the trading loop.
# When NEUROLINKED_TOKEN is empty, the bridge is disabled (no-op).
NEUROLINKED_URL=https://brain.shadowmarket.ai
NEUROLINKED_TOKEN=                     # required — no default. Tenant: trading_os
NEUROLINKED_ENABLED=true

# ── Authentication ─────────────────────────────────────────
# Opt-in. When AUTH_ENABLED=true, JWT_SECRET_KEY MUST be overridden —
# the app will refuse to start with the placeholder default. Generate a
# strong secret with: openssl rand -hex 32
AUTH_ENABLED=false
ADMIN_EMAIL=sales@shadowmarket.ai
ADMIN_PASSWORD_HASH=                   # bcrypt hash — run scripts/hash_password.py
JWT_SECRET_KEY=change-this-in-production
JWT_EXPIRE_MINUTES=480
